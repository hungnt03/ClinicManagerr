<h3>Chưa chấm công</h3>

<p>
    Ngày: @ViewBag.Ngay.ToString("dd/MM/yyyy")
</p>

@if (User.IsInRole("Admin"))
{
    <a class="btn btn-primary"
       asp-action="Index">
        Tạo chấm công mới
    </a>
}
else
{
    <p class="text-muted">
		Chưa có dữ liệu chấm công cho ngày này. 
        Vui lòng liên hệ Admin để tạo chấm công.
    </p>
}
