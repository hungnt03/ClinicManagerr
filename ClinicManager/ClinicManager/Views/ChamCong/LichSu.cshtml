@{
    ViewData["Title"] = "Lich su cham cong";
}

<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

@if (User.IsInRole("Admin"))
{
    <div class="mb-2">
        <label>Chon nhan vien</label>
        <select id="nhanVienSelect" class="form-control"></select>
    </div>
}

<div id="calendar"></div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        let calendarEl = document.getElementById('calendar');
        let nhanVienSelect = document.getElementById('nhanVienSelect');

        // ============================
        // LOAD NHAN VIEN (ADMIN)
        // ============================
        if (nhanVienSelect) {
            fetch('/ChamCong/DanhSachNhanVien')
                .then(res => res.json())
                .then(data => {
                    data.forEach(nv => {
                        let opt = document.createElement('option');
                        opt.value = nv.id;
                        opt.text = nv.text;
                        nhanVienSelect.appendChild(opt);
                    });

                    // sau khi load xong -> render calendar
                    renderCalendar();
                });

            nhanVienSelect.addEventListener('change', function () {
                calendar.refetchEvents();
            });
        } else {
            // user thường
            renderCalendar();
        }

        let calendar;

        // ============================
        // RENDER CALENDAR
        // ============================
        function renderCalendar() {
            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                height: 'auto',

                events: function (info, successCallback) {

                    let url = `/ChamCong/CalendarData?
                        month=${info.start.getMonth() + 1}
                        &year=${info.start.getFullYear()}`;

                    if (nhanVienSelect) {
                        url += `&nhanVienId=${nhanVienSelect.value}`;
                    }

                    fetch(url)
                        .then(res => res.json())
                        .then(data => successCallback(data));
                },

                eventClick: function (info) {
                    window.location.href =
                        `/ChamCong/ChiTiet/${info.event.id}`;
                },

                eventContent: function (arg) {
                    let smallScreen = window.innerWidth < 576;

                    if (smallScreen) {
                        return { html: `<div>${arg.event.title}</div>` };
                    }

                    let gioVao = arg.event.extendedProps.gioVao || '';
                    let gioRa = arg.event.extendedProps.gioRa || '';

                    return {
                        html: `<div>${gioVao} - ${gioRa}</div>`
                    };
                }
            });

            calendar.render();
        }
    });
</script>
