@model ClinicManager.ViewModels.Luong.CauHinhLuongVm

@{
    ViewData["Title"] = "Chi tiết cấu hình lương";
}

<h3>Chi tiết cấu hình lương</h3>

<table class="table table-bordered">
    <tbody>
        <tr class="table-secondary">
            <th colspan="2">Hiệu lực</th>
        </tr>
        <tr>
            <td>Áp dụng từ ngày</td>
            <td>@Model.ApDungTuNgay.ToString("dd/MM/yyyy")</td>
        </tr>

        <tr class="table-secondary">
            <th colspan="2">Giờ làm việc</th>
        </tr>
        <tr>
            <td>Sáng</td>
            <td>
                @Model.GioBatDauSang.ToString(@"hh\:mm")
                -
                @Model.GioKetThucSang.ToString(@"hh\:mm")
            </td>
        </tr>
        <tr>
            <td>Chiều</td>
            <td>
                @Model.GioBatDauChieu.ToString(@"hh\:mm")
                -
                @Model.GioKetThucChieu.ToString(@"hh\:mm")
            </td>
        </tr>
        <tr>
            <td>Số giờ làm chuẩn / ngày</td>
            <td>@Model.SoGioLamChuanNgay</td>
        </tr>

        <tr class="table-secondary">
            <th colspan="2">Phụ cấp</th>
        </tr>
        <tr>
            <td>Ăn trưa / ngày</td>
            <td>@Model.TienAnTruaNgay.ToString("N0")</td>
        </tr>
        <tr>
            <td>Xăng xe / tháng</td>
            <td>@Model.TienXangXeThang.ToString("N0")</td>
        </tr>
        <tr>
            <td>Chuyên cần</td>
            <td>@Model.TienChuyenCan.ToString("N0")</td>
        </tr>

        <tr class="table-secondary">
            <th colspan="2">Hoa hồng</th>
        </tr>
        <tr>
            <td>Điều trị tay / buổi</td>
            <td>@Model.TienDieuTriTayMoiBuoi.ToString("N0")</td>
        </tr>
        <tr>
            <td>Tiền tập / buổi</td>
            <td>@Model.TienTapMoiBuoi.ToString("N0")</td>
        </tr>
        <tr>
            <td>% giới thiệu</td>
            <td>@Model.PhanTramGioiThieu %</td>
        </tr>

        <tr class="table-secondary">
            <th colspan="2">Tăng ca</th>
        </tr>
        <tr>
            <td>Hệ số ngày lễ / Chủ nhật</td>
            <td>@Model.DonGiaTangCaMoiGio</td>
        </tr>
        <tr>
            <td>Làm tròn tăng ca</td>
            <td>@Model.SoPhutLamTronTangCa phut</td>
        </tr>
        <tr>
            <td>Tối thiểu tính tăng ca</td>
            <td>@Model.SoPhutToiThieuTinhTangCa phut</td>
        </tr>
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">
    Quay lại
</a>
