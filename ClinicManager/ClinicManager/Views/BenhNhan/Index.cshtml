@model List<ClinicManager.ViewModels.BenhNhan.BenhNhanListItemVm>

<h2>Danh sách bệnh nhân</h2>

<p>
    <a class="btn btn-primary" asp-action="Tao">
        + Thêm bệnh nhân
    </a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Giới tính</th>
            <th>Tuổi</th>
            <th>Số điện thoại</th>
            <th>Người giới thiệu</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td><a asp-controller="BenhNhan"
                   asp-action="ChiTiet"
                   asp-route-id="@b.BenhNhanId"
                   class="fw-bold text-decoration-none">
                    @b.HoTen
                </a></td>                
                <td>@b.GioiTinh</td>
                <td>@b.Tuoi</td>
                <td>@b.SoDienThoai</td>
                <td>@b.NguoiGioiThieu</td>
                <td>
                    <a asp-action="Sua"
                       asp-route-id="@b.BenhNhanId"
                       class="btn btn-sm btn-info">
                        Sửa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
