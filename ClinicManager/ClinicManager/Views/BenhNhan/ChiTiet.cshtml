@model ClinicManager.ViewModels.BenhNhan.BenhNhanChiTietVm
@{
    ViewData["Title"] = "Chi tiết bệnh nhân";
}

<h3>Thông tin bệnh nhân</h3>

<div class="card mb-3">
    <div class="card-body">
        <p><b>Họ tên:</b> @Model.HoTen</p>
        <p><b>Ngày sinh:</b> @(Model.NgaySinh?.ToString("dd/MM/yyyy") ?? "—")</p>
        <p><b>Giới tính:</b> @Model.GioiTinh</p>
        <p><b>Số điện thoại:</b> @Model.SoDienThoai</p>
        <p><b>Địa chỉ:</b> @Model.DiaChi</p>
    </div>
</div>

<h4>Các đợt điều trị</h4>
<a class="btn btn-success"
   asp-controller="DotDieuTri"
   asp-action="Create"
   asp-route-benhNhanId="@Model.BenhNhanId">
    + Tạo đợt điều trị mới
</a>
<br />
@if (!Model.DotDieuTris.Any())
{
    <p class="text-muted">Chưa có đợt điều trị nào</p>
}
else
{
    <div class="accordion" id="accordionDotDieuTri">

        @for (int i = 0; i < Model.DotDieuTris.Count; i++)
        {
            var dot = Model.DotDieuTris[i];
            var headingId = $"heading{i}";
            var collapseId = $"collapse{i}";
            <div class="accordion-item">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(i > 0 ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId">
                        Đợt khám @dot.NgayKham.ToString("dd/MM/yyyy")
                        — @dot.TrangThai
                    </button>
                </h2>

                <div id="@collapseId"
                     class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                     data-bs-parent="#accordionDotDieuTri">
                    <div class="accordion-body">

                        <p><b>Chẩn đoán:</b> @dot.ChanDoan</p>
                        <p><b>Phác đồ:</b> @dot.PhacDoDieuTri</p>

                        <p>
                            <b>Số buổi:</b>
                            @dot.SoBuoiDaDung / @dot.TongSoBuoi
                        </p>

                        <p>
                            <b>Thanh toán:</b>
                            @dot.DaThanhToan.ToString("N0")
                            /
                            @dot.TongTien.ToString("N0")
                        </p>

                        <a class="btn btn-sm btn-primary"
                           asp-controller="DotDieuTri"
                           asp-action="ChiTiet"
                           asp-route-id="@dot.DotDieuTriId">
							Xem các buổi điều trị
                        </a>

                    </div>
                </div>
            </div>
        }
    </div>
}
