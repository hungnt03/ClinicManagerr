@model ClinicManager.ViewModels.BenhNhan.BenhNhanFormVm

<h2>@(Model.BenhNhanId == 0 ? "Them benh nhan" : "Sua benh nhan")</h2>

<form method="post">
    <input type="hidden" asp-for="BenhNhanId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label>Ho ten</label>
        <input asp-for="HoTen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Ngay sinh</label>
        <input asp-for="NgaySinh" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label>Gioi tinh</label>
        <select asp-for="GioiTinh" class="form-control">
            <option value="">--</option>
            <option>Nam</option>
            <option>Nu</option>
        </select>
    </div>

    <div class="form-group">
        <label>Dien thoai</label>
        <input asp-for="SoDienThoai" class="form-control" />
    </div>

    <div class="form-group">
        <label>Dia chi</label>
        <input asp-for="DiaChi" class="form-control" />
    </div>

    <div class="form-group">
        <label>Nguoi gioi thieu</label>
        <select asp-for="NguoiGioiThieuId" class="form-control">
            <option value="">-- Khong co --</option>
            @foreach (var nv in Model.DanhSachNhanVien)
            {
                <option value="@nv.NhanVienId">@nv.HoTen</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Luu
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Quay lai
    </a>
</form>
