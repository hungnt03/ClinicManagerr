@model ClinicManager.ViewModels.BenhNhan.BenhNhanFormVm

<h2>@(Model.BenhNhanId == 0 ? "Thêm bệnh nhân" : "Sửa bệnh nhân")</h2>

<form method="post">
    <input type="hidden" asp-for="BenhNhanId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label>Họ tên</label>
        <input asp-for="HoTen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Ngày sinh</label>
        <input asp-for="NgaySinh" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label>Giới tính</label>
        <select asp-for="GioiTinh" class="form-control">
            <option value="">--</option>
            <option>Nam</option>
            <option>Nữ</option>
        </select>
    </div>

    <div class="form-group">
        <label>Số điện thoại</label>
        <input asp-for="SoDienThoai" class="form-control" />
    </div>

    <div class="form-group">
        <label>Địa chỉ</label>
        <input asp-for="DiaChi" class="form-control" />
    </div>

    <div class="form-group">
        <label>Người giới thiệu</label>
        <select asp-for="NguoiGioiThieuId" class="form-control">
            <option value="">-- Không có --</option>
            @foreach (var nv in Model.DanhSachNhanVien)
            {
                <option value="@nv.NhanVienId">@nv.HoTen</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Lưu
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</form>
