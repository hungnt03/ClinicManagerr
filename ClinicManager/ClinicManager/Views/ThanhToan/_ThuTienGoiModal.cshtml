@using ClinicManager.Models.Entities
@model ClinicManager.ViewModels.ThanhToan.ThuTienGoiVm

<div class="modal fade" id="modalThuTien" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="formThuTien">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="DotDieuTriId" />

                <div class="modal-header">
                    <h5 class="modal-title">Thu tiền gói điều trị</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <!-- ===== TỔNG TIỀN GỐC ===== -->
                    <div class="mb-2">
                        <label>Tổng tiền gói</label>
                        <input class="form-control"
                               value="@Model.TongTien.ToString("N0")"
                               disabled />
                    </div>

                    <!-- ===== GIẢM GIÁ ===== -->
                    @if (Model.PhanTramGiamGia > 0)
                    {
                        <div class="mb-2">
                            <label>Giảm giá (%)</label>
                            <input class="form-control"
                                   value="@Model.PhanTramGiamGia"
                                   disabled />
                        </div>

                        <div class="mb-2">
                            <label>Tiền giảm</label>
                            <input class="form-control text-danger"
                                   value="-@Model.TienGiam.ToString("N0")"
                                   disabled />
                        </div>
                    }

                    <!-- ===== ĐÃ THANH TOÁN ===== -->
                    <div class="mb-2">
                        <label>Đã thanh toán</label>
                        <input class="form-control"
                               value="@Model.DaThanhToan.ToString("N0")"
                               disabled />
                    </div>

                    <!-- ===== CÒN LẠI ===== -->
                    <div class="mb-2">
                        <label>Còn lại cần thu</label>
                        <input class="form-control fw-bold text-danger"
                               value="@Model.ConLai.ToString("N0")"
                               disabled />
                    </div>

                    <hr />

                    <!-- ===== NHẬP SỐ TIỀN THU ===== -->
                    <div class="mb-2">
                        <label>Số tiền thu</label>
                        <input asp-for="SoTienThu"
                               class="form-control"
                               value="@Model.ConLai" />
                    </div>

                    <div class="mb-2">
                        <label>Hình thức thanh toán</label>
                        <select asp-for="HinhThuc"
                                asp-items="Html.GetEnumSelectList<HinhThucThanhToan>()"
                                class="form-control">
                        </select>
                    </div>

                    <div class="mb-2">
                        <label>Ghi chú</label>
                        <textarea asp-for="GhiChu"
                                  class="form-control"
                                  rows="2"></textarea>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit"
                            class="btn btn-primary">
                        Thu tiền
                    </button>

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Đóng
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
