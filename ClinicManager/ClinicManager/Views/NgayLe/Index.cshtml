@model List<ClinicManager.ViewModels.Luong.NgayLeVm>

@{
    ViewData["Title"] = "Ngày lễ";
}

<h3>Danh sách ngày lễ</h3>

<a class="btn btn-primary mb-2" asp-action="Create">
    + Thêm ngày lễ
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ngày</th>
            <th>Tên</th>
            <th>Tính lương</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var x in Model)
        {
            <tr>
                <td>@x.Ngay.ToString("dd/MM/yyyy")</td>
                <td>@x.Ten</td>
                <td>
                    @if (x.CoTinhLuong)
                    {
                        <span class="badge bg-success">Có</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Không</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
