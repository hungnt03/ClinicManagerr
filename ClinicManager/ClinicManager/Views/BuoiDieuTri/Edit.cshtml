@model ClinicManager.ViewModels.BuoiDieuTri.BuoiDieuTriEditVm

@{
    ViewData["Title"] = "Sửa buổi điều trị";
}

<h3>Sửa buổi điều trị</h3>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <!-- ===== HIDDEN ===== -->
    <input type="hidden" asp-for="BuoiDieuTriId" />
    <input type="hidden" asp-for="DotDieuTriId" />
    <input type="hidden" asp-for="BenhNhanId" />

    <!-- ===== THỜI GIAN ===== -->
    <div class="mb-3">
        <label class="form-label">Ngày điều trị</label>
        <input asp-for="NgayDieuTri" type="date" class="form-control" />
        <span asp-validation-for="NgayDieuTri" class="text-danger"></span>
    </div>

    <!-- ===== NHÂN SỰ ===== -->
    <div class="mb-3">
        <label class="form-label">Bác sĩ điều trị tay</label>
        <select asp-for="BacSiDieuTriTayId"
                asp-items="Model.DanhSachBacSiDieuTriTay"
                class="form-control">
            <option value="">-- Không có --</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Kỹ thuật viên tập</label>
        <select asp-for="KyThuatVienTapId"
                asp-items="Model.DanhSachNguoiTap"
                class="form-control">
            <option value="">-- Không có --</option>
        </select>
    </div>

    <!-- ===== NỘI DUNG ===== -->
    <div class="mb-3">
        <label class="form-label">Nội dung tập</label>
        <textarea asp-for="NoiDungTap" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Nội dung điều trị tay</label>
        <textarea asp-for="NoiDungDieuTriTay" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Chỉ định đặc biệt</label>
        <textarea asp-for="ChiDinhDacBiet" class="form-control"></textarea>
    </div>

    <!-- ===== CHI PHÍ ===== -->
    <div class="mb-3">
        <label class="form-label">Chi phí thuốc / vật tư</label>
        <input class="form-control"
               value="@Model.ChiPhiThuocVatTu.ToString("N0")"
               readonly />
    </div>

    <!-- ===== AUDIT ===== -->
    <div class="mb-3">
        <label class="form-label text-danger">
            Lý do sửa (bắt buộc)
        </label>
        <textarea asp-for="LyDoSua"
                  class="form-control"
                  required></textarea>
        <span asp-validation-for="LyDoSua" class="text-danger"></span>
    </div>

    <button type="button"
            class="btn btn-warning"
            id="btnThuTienThuoc"
            data-buoiid="@Model.BuoiDieuTriId">
        Thu tiền thuốc / vật tư
    </button>

    <!-- ===== ACTION ===== -->
    <button class="btn btn-primary">
        Lưu thay đổi
    </button>

    <a class="btn btn-secondary"
       asp-controller="DotDieuTri"
       asp-action="ChiTiet"
       asp-route-id="@Model.DotDieuTriId">
        Hủy
    </a>
</form>

<div id="modalThuocContainer"></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
