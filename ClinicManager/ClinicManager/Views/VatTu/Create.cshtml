@model ClinicManager.ViewModels.VatTu.VatTuCreateEditVm
@using ClinicManager.Models.Entities

<h3>@(Model.VatTuId == null ? "Thêm vật tư" : "Sửa vật tư")</h3>

<form method="post">
    @Html.AntiForgeryToken()

    <div class="mb-2">
        <label>Tên vật tư</label>
        <input asp-for="TenVatTu" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Loại</label>
        <select asp-for="Loai"
                asp-items="Html.GetEnumSelectList<LoaiVatTu>()"
                class="form-control">
        </select>
    </div>

    <div class="mb-2">
        <label>Đơn vị tính</label>
        <input asp-for="DonViTinh" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Đơn giá</label>
        <input asp-for="DonGia" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Tồn kho</label>
        <input asp-for="TonKho" class="form-control" />
    </div>

    <button class="btn btn-primary">Lưu</button>
    <a class="btn btn-secondary" asp-action="Index">Quay lại</a>
</form>
