@model ClinicManager.ViewModels.DotDieuTri.DotDieuTriChiTietVm

@{
    ViewData["Title"] = "Chi tiết đợt điều trị";

    int soBuoiConLai = Model.TongSoBuoi - Model.SoBuoiDaDung;

    // ===== MAU CANH BAO =====
    string cssCanhBao =
        soBuoiConLai <= 0 ? "bg-secondary text-white" :
        soBuoiConLai < 2 ? "bg-warning" :
        "";
}

<h3>Chi tiết đợt điều trị</h3>

<!-- ================== THONG TIN DOT ================== -->
<div class="card mb-3 @cssCanhBao">
    <div class="card-body">

        <div class="mb-2">
            <b>Tiền sử bệnh:</b>
            <div class="preserve-format text-muted ms-2">@Model.TienSuBenh</div>
        </div>

        <div class="mb-2">
            <b>Chẩn đoán:</b>
            <div class="preserve-format text-muted ms-2">@Model.ChanDoan</div>
        </div>

        <div class="mb-2">
            <b>Phác đồ điều trị:</b>
            <div class="preserve-format text-muted ms-2">@Model.PhacDoDieuTri</div>
        </div>

        <p class="mt-3">
            <b>Số buổi:</b>
            @Model.SoBuoiDaDung / @Model.TongSoBuoi
        </p>

        <p>
            <b>Trạng thái:</b>
            <span class="badge bg-info">@Model.TrangThai</span>
        </p>

        <!-- ===== NUT TAO BUOI ===== -->
        @if (soBuoiConLai > 0)
        {
            <a class="btn btn-success"
               asp-controller="BuoiDieuTri"
               asp-action="Create"
               asp-route-dotDieuTriId="@Model.DotDieuTriId"
               asp-route-benhNhanId="@Model.BenhNhanId">
                + Tạo buổi điều trị
            </a>
        }
        else
        {
            <button class="btn btn-secondary" disabled>
                Đã hết số buổi điều trị
            </button>
        }

        <button class="btn btn-success"
                id="btnThuTien"
                data-dotid="@Model.DotDieuTriId">
            Thu tiền gói
        </button>

        <button class="btn btn-success"
                id="btnPhieuKham"
                data-dotid="@Model.DotDieuTriId">
            Tạo phiếu khám
        </button>

        <div id="modalContainer"></div>
    </div>
</div>

<!-- ================== DANH SACH BUOI ================== -->

<h4>Danh sách cách buổi điều trị</h4>

@if (Model.BuoiDieuTris == null || !Model.BuoiDieuTris.Any())
{
    <p class="text-muted">Chưa có buổi điều trị nào</p>
}
else
{
    <div class="accordion" id="accordionBuoiDieuTri">

        @for (int i = 0; i < Model.BuoiDieuTris.Count; i++)
        {
            var buoi = Model.BuoiDieuTris[i];
            var headingId = $"headingBuoi{i}";
            var collapseId = $"collapseBuoi{i}";

            <div class="accordion-item">

                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(i > 0 ? "collapsed" : "")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId">
                        Buổi điều trị - @buoi.NgayDieuTri.ToString("dd/MM/yyyy")
                    </button>
                </h2>

                <div id="@collapseId"
                     class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                     data-bs-parent="#accordionBuoiDieuTri">

                    <div class="accordion-body">

                        <p>
                            <b>Bác sỹ điều trị tay:</b>
                            @(string.IsNullOrEmpty(buoi.TenBacSiDieuTriTay)
                                                ? "—"
                                                : buoi.TenBacSiDieuTriTay)
                        </p>

                        <p>
                            <b>Bác sỹ tập:</b>
                            @(string.IsNullOrEmpty(buoi.TenNguoiTap)
                                                ? "—"
                                                : buoi.TenNguoiTap)
                        </p>

                        @if (!string.IsNullOrEmpty(buoi.NoiDungTap))
                        {
                            <p>
                                <b>Nội dung tập:</b>
                                @buoi.NoiDungTap
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(buoi.NoiDungDieuTriTay))
                        {
                            <p>
                                <b>Nội dung điều trị tay:</b>
                                @buoi.NoiDungDieuTriTay
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(buoi.ChiDinhDacBiet))
                        {
                            <p class="text-danger">
                                <b>Chỉ định đặc biệt:</b>
                                @buoi.ChiDinhDacBiet
                            </p>
                        }

                        <p>
                            <b>Chi phí thuốc / vật tư:</b>
                            @buoi.ChiPhiThuocVatTu.ToString("N0")
                        </p>

                        @if (User.IsInRole("Admin") || User.IsInRole("BacSi"))
                        {
                            <a class="btn btn-sm btn-outline-secondary"
                               asp-controller="BuoiDieuTri"
                               asp-action="Edit"
                               asp-route-buoiDieuTriId="@buoi.BuoiDieuTriId">
								Quản lý buổi điều trị
                            </a>
                        }
                    </div>
                </div>

            </div>
        }
    </div>

    <div class="modal fade" id="modalPhieuKham" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">PHIẾU LƯỢNG GIÁ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formPhieuKham">
                        <input type="hidden" id="modalDotDieuTriId" />
                    
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label>Tên BN:</label>
                                <input type="text" id="modalTenBN" class="form-control" readonly />
                            </div>
                            <div class="col-md-6">
                                <label>Số điện thoại:</label>
                                <input type="text" id="modalSDT" class="form-control" readonly />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Tiền sử và hiện tại:</label>
                            <textarea id="modalTienSu" class="form-control" rows="4" placeholder="Nhập tiền sử bệnh..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Tiên lượng:</label>
                            <textarea id="modalTienLuong" class="form-control" rows="3"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold">Phương án điều trị:</label>
                            <textarea id="modalPhuongAn" class="form-control" rows="3"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" onclick="LuuPhieuKham()">Lưu và In</button>
                </div>
            </div>
        </div>
    </div>
}
