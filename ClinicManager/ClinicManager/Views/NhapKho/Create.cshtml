@model ClinicManager.ViewModels.NhapKho.NhapKhoCreateVm

<h3>Nhập kho</h3>

<form method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row mb-3">
        <div class="col-md-4">
            <label>Ngày nhập</label>
            <input asp-for="NgayNhap" type="date" class="form-control" />
        </div>
        <div class="col-md-8">
            <label>Hóa đơn (PDF / Ảnh)</label>
            <input asp-for="HoaDonFile" type="file"
                   class="form-control"
                   accept=".pdf,.jpg,.jpeg,.png" />
        </div>
    </div>

    <div class="mb-3">
        <label>Ghi chú</label>
        <textarea asp-for="GhiChu" class="form-control"></textarea>
    </div>

    <!-- ===== BUTTON ADD ===== -->
    <button type="button"
            class="btn btn-outline-primary mb-2"
            data-bs-toggle="modal"
            data-bs-target="#modalVatTu">
        + Thêm vật tư
    </button>

    <!-- ===== TABLE CHI TIET ===== -->
    <table class="table table-bordered" id="tblVatTu">
        <thead>
            <tr>
                <th>Vật tư</th>
                <th>Số lượng</th>
                <th>Đơn giá nhập</th>
                <th>Thành tiền</th>
                <th></th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    <div class="text-end mb-3">
        <strong>Tổng tiền: </strong>
        <span id="tongTien">0</span>
    </div>

    <!-- ===== HIDDEN ITEMS ===== -->
    <div id="itemsContainer"></div>

    <button class="btn btn-primary">
        Lưu phiếu nhập
    </button>

    <a class="btn btn-secondary"
       asp-controller="VatTu"
       asp-action="Index">
        Quay lại
    </a>
</form>

<!-- ================= MODAL VAT TU ================= -->
<div class="modal fade" id="modalVatTu" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Thêm vật tư</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <div class="mb-2">
                    <label>Vật tư</label>
                    <select id="vatTuId" class="form-control"></select>
                </div>

                <div class="mb-2">
                    <label>Số lượng</label>
                    <input id="soLuong" type="number" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>Đơn giá nhập</label>
                    <input id="donGiaNhap" type="number" class="form-control" />
                </div>

            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" id="btnThem">
                    Thêm
                </button>
            </div>
        </div>
    </div>
</div>
