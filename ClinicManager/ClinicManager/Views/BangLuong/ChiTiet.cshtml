@model ClinicManager.ViewModels.Luong.BangLuongThangChiTietVm

@{
    ViewData["Title"] = $"Bảng lương {Model.Thang}/{Model.Nam}";
}

<h3>Bảng lương tháng @Model.Thang/@Model.Nam</h3>

@if (User.IsInRole("Admin"))
{
    <form asp-action="@(Model.DaChot ? "MoChotLuong" : "ChotLuong")"
          method="post"
          class="mb-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.BangLuongThangId" />

        @if (!Model.DaChot)
        {
            <button class="btn btn-danger"
                    onclick="return confirm('Chot bang luong? Sau khi chot se khong sua duoc!')">
                🔒 Chốt bảng lương
            </button>
        }
        else
        {
            <button class="btn btn-warning"
                    onclick="return confirm('Mo chot bang luong?')">
                🔓 Mở chốt
            </button>
        }
    </form>
}

<div class="accordion" id="accordionLuong">
    @for (int i = 0; i < Model.NhanViens.Count; i++)
    {
        var nv = Model.NhanViens[i];
        var collapseId = $"collapse{i}";
        <div class="accordion-item">
            <h2 class="accordion-header">
                <button class="accordion-button @(i > 0 ? "collapsed" : "")"
                        data-bs-toggle="collapse"
                        data-bs-target="#@collapseId">
                    @nv.TenNhanVien — <strong>@nv.TongLuong.ToString("N0")</strong>
                </button>
                <button type="button"
                        class="btn btn-sm btn-outline-success ms-3 btn-them-phat-sinh"
                        data-id="@nv.nhanVienId"
                        data-ten="@nv.TenNhanVien">
                    <i class="bi bi-plus-circle"></i> + Thêm phát sinh
                </button>
            </h2>

            <div id="@collapseId"
                 class="accordion-collapse collapse @(i == 0 ? "show" : "")">
                <div class="accordion-body">
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Loại</th>
                                <th>Diễn giải</th>
                                <th>Số tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ct in nv.ChiTiets)
                            {
                                <tr>
                                    <td>@ct.loai</td>
                                    <td>@ct.dienGiai</td>
                                    <td>@ct.soTien.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal Thêm Phát Sinh -->
<div class="modal fade" id="modalPhatSinh" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="ThemPhatSinh" method="post">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm khoản phát sinh: <span id="spanTenNV"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="BangLuongThangId" value="@Model.BangLuongThangId" />
                    <input type="hidden" name="NhanVienId" id="inputNhanVienId" />
                    
                    <div class="mb-3">
                        <label class="form-label">Loại</label>
                        <select name="Loai" class="form-select">
                            <option value="1">➕ Thưởng / Cộng thêm</option>
                            <option value="2">➖ Phạt / Khấu trừ</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số tiền</label>
                        <input type="number" name="SoTien" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung diễn giải</label>
                        <textarea name="NoiDung" class="form-control" rows="2" required placeholder="Ví dụ: Thưởng dự án, Phạt đi muộn..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Lưu phát sinh</button>
                </div>
            </div>
        </form>
    </div>
</div>