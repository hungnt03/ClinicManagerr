@model List<ClinicManager.ViewModels.Luong.BangLuongThangListItemVm>

@{
    ViewData["Title"] = "Bảng lương theo tháng";
}

<h3>Bảng lương theo tháng</h3>

<form asp-action="TinhLuong" method="post" class="row g-2 mb-3">
    @Html.AntiForgeryToken()
    <div class="col-auto">
        <input type="number" name="thang" class="form-control" placeholder="Thang" min="1" max="12" required />
    </div>
    <div class="col-auto">
        <input type="number" name="nam" class="form-control" placeholder="Nam" required />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary">Tính lương</button>
    </div>
</form>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>Tháng</th>
            <th>Năm</th>
            <th>Số nhân viên</th>
            <th>Tổng lương</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var x in Model)
        {
            <tr>
                <td>@x.Thang</td>
                <td>@x.Nam</td>
                <td>@x.SoNhanVien</td>
                <td>@x.TongLuong.ToString("N0")</td>
                <td>
                    @if (x.DaChot)
                    {
                        <span class="badge bg-success">Đã chốt</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Chưa chốt</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-outline-primary"
                       asp-action="ChiTiet"
                       asp-route-id="@x.BangLuongThangId">
                        Chi tiết
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>