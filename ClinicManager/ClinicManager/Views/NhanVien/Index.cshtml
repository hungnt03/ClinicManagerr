@model List<ClinicManager.ViewModels.NhanVien.NhanVienListItemVm>

@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<h2>Danh sach nhan vien</h2>

<p>
    <a class="btn btn-primary" asp-action="Tao">
        + Tạo nhân viên
    </a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Vai trò</th>
            <th>Lương cơ bản</th>
            <th>Tài khoản</th>
            <th>Trạng thái</th>
            <th style="width:200px">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.HoTen</td>
                <td>@item.VaiTro</td>
                <td>@item.LuongCoBan.ToString("N0")</td>
                <td>
                    @if (item.CoTaiKhoan)
                    {
                        <span class="text-success">
                            @item.EmailDangNhap
                        </span>
                    }
                    else
                    {
                        <span class="text-danger">
                            chưa có tài khoản
                        </span>
                    }
                </td>
                <td>
                    @if (item.HoatDong)
                    {
                        <span class="">Hoạt động</span>
                    }
                    else
                    {
                        <span class="">Khóa</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-info"
                       asp-action="Sua"
                       asp-route-id="@item.NhanVienId">
                        Sửa
                    </a>

                    @if (item.CoTaiKhoan)
                    {
                        <form asp-action="@(item.BiKhoaTaiKhoan ? "MoKhoaTaiKhoan" : "KhoaTaiKhoan")"
                              method="post"
                              style="display:inline">
                            <input type="hidden" name="nhanVienId" value="@item.NhanVienId" />
                            @Html.AntiForgeryToken()

                            @if (item.BiKhoaTaiKhoan)
                            {
                                <button class="btn btn-sm btn-success">
                                    Mở
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-danger"
                                        onclick="return confirm('Khoa tai khoan nay?')">
                                    Khóa
                                </button>
                            }
                        </form>
                        <a class="btn btn-sm btn-warning"
                           asp-action="ResetMatKhau"
                           asp-route-id="@item.NhanVienId">
                            Reset MK
                        </a>
                    }
                </td>

            </tr>
        }
    </tbody>
</table>
