@model ClinicManager.ViewModels.NhanVien.ResetMatKhauVm

@{
    ViewData["Title"] = "Reset mat khau";
}

<h2>Reset mat khau</h2>

<form asp-action="ResetMatKhau" method="post">
    <input type="hidden" asp-for="NhanVienId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label>Email dang nhap</label>
        <input asp-for="Email" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Mat khau moi</label>
        <input asp-for="MatKhauMoi" type="password" class="form-control" />
    </div>

    <div class="form-group">
        <label>Xac nhan mat khau</label>
        <input asp-for="XacNhanMatKhau" type="password" class="form-control" />
    </div>

    <button type="submit" class="btn btn-danger">
        Reset mat khau
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Quay lai
    </a>
</form>
