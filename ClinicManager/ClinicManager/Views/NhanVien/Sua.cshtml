@model ClinicManager.ViewModels.NhanVien.SuaNhanVienVm

@{
    ViewData["Title"] = "Sửa nhân viên";
}

<h2>Sửa nhân viên</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Sua" method="post">
    <input type="hidden" asp-for="NhanVienId" />

    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label>Họ tên</label>
        <input asp-for="HoTen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Vai trò nhân viên</label>
        <select asp-for="VaiTroNhanVien" class="form-control">
            @foreach (var v in Model.DanhSachVaiTroNhanVien)
            {
                <option value="@v">@v</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Lương cơ bản</label>
        <input asp-for="LuongCoBan" class="form-control" />
    </div>

    <div class="form-group">
        <label>Trạng thái</label>
        <select asp-for="HoatDong" class="form-control">
            <option value="true">Hoạt động</option>
            <option value="false">Khóa</option>
        </select>
    </div>

    <hr />

    <div class="form-group">
        <label>Role đăng nhập</label>
        <select asp-for="RoleDangNhap" class="form-control">
            @foreach (var r in Model.DanhSachRoleDangNhap)
            {
                <option value="@r">@r</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Lưu thay đổi
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Quay lại
    </a>
</form>
