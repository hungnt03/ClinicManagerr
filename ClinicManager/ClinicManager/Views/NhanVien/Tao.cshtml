@using ClinicManager.ViewModels.NhanVien
@model TaoNhanVienTaiKhoanVm

@{
    ViewData["Title"] = "Tạo nhân viên và tài khoản";
}

<h2>Tạo nhân viên và tài khoản</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<form asp-action="Tao" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label>Họ tên</label>
        <input asp-for="HoTen" class="form-control" />
    </div>

    <div class="form-group">
        <label>Vai trò nhân viên</label>
        <select asp-for="VaiTroNhanVien" class="form-control">
            <option value="">-- Chon --</option>
            @foreach (var v in Model.DanhSachVaiTro)
            {
                <option value="@v">@v</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Lương cơ bản</label>
        <input asp-for="LuongCoBan" class="form-control" />
    </div>

    <hr />

    <div class="form-group">
        <label>Email đăng nhập</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label>Mật khẩu</label>
        <input asp-for="MatKhau" type="password" class="form-control" />
    </div>

    <div class="form-group">
        <label>Role đăng nhập</label>
        <select asp-for="RoleDangNhap" class="form-control">
            <option value="">-- Chon --</option>
            @foreach (var r in Model.DanhSachRole)
            {
                <option value="@r">@r</option>
            }
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        Tạo tài khoản
    </button>
</form>
